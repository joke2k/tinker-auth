{
    "name": "joke2k/tinker-auth",
    "description": "Authenticated sessions for Laravel Tinker with strict/optional modes and command-level auth trait.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "tinker",
        "artisan",
        "auth",
        "security"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "laravel/tinker": "^2.11"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^1.11",
        "laravel/pint": "^1.0",
        "rector/rector": "^1.2"
    },
    "suggest": {
        "laravel/prompts": "Enables enhanced interactive authentication prompts."
    },
    "autoload": {
        "psr-4": {
            "Joke2k\\TinkerAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Joke2k\\TinkerAuth\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "analyse": "./vendor/bin/phpstan analyse --memory-limit=512M",
        "rector": "./vendor/bin/rector process",
        "rector:dry": "./vendor/bin/rector process --dry-run",
        "format": "./vendor/bin/pint",
        "format:check": "./vendor/bin/pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Joke2k\\TinkerAuth\\TinkerAuthServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
